  "keyFeatures": [
    "AI-powered semantic search using vector embeddings",
    "RAG (Retrieval-Augmented Generation) for intelligent Q&A",
    "Multi-format content storage (articles, videos, tweets, documents)",
    "Tag-based organization and filtering",
    "Public sharing via unique share links",
    "JWT-based authentication and user accounts",
    "Cosine similarity ranking for relevance scoring",
    "Exponential backoff retry mechanism for AI API calls"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/signup - Create user account",
    "POST /api/v1/auth/signin - Authenticate and get JWT token",
    "POST /api/v1/content - Save new content with auto-embedding",
    "GET /api/v1/content - List content with filters (type, tag)",
    "DELETE /api/v1/content - Delete content item",
    "POST /api/v1/brain/query - AI-powered Q&A against saved content",
    "POST /api/v1/brain/search - Semantic similarity search",
    "POST /api/v1/brain/share - Toggle public sharing",
    "GET /api/v1/brain/:shareLink - View publicly shared brain"
  ]
